@startuml Activity_05_Buat_Pengaduan

skinparam roundcorner 10
skinparam BackgroundColor white
skinparam shadowing false
skinparam ActivityBackgroundColor #FEFEFE
skinparam ActivityBorderColor #555555
skinparam ActivityFontSize 11

title Activity Diagram 5 - Buat Pengaduan Baru\nSistem Informasi Kantor Lurah Maharatu

|#E8F5E9|Masyarakat|
start
:Pilih Tab/Menu Pengaduan;
:Tampilkan PengaduanView;
note right
  2 Pilihan menu:
  1. Buat Pengaduan Baru
  2. Pengaduan Saya
end note
:Pilih "Buat Pengaduan Baru";
:Tampilkan InputPengaduanView;
:Isi Form Pengaduan;
note right
  DATA PELAPOR:
  - Nama Lengkap (wajib)
  - NIK (wajib, tepat 16 digit angka)
  - Tanggal Kejadian (DatePicker,
    prefill hari ini, range 2000-sekarang)
  - Alamat (TextArea, 2-4 baris, wajib)

  ISI PENGADUAN:
  - Uraian Pengaduan (TextArea, 4-8 baris,
    wajib, min 20 karakter)

  LAMPIRAN:
  - Foto/Bukti (opsional, FileUploadField)
end note

if (Ingin lampirkan foto?) then (Ya)
  :Tekan area upload;
  |#FFF9C4|Sistem|
  :Tampilkan BottomSheet\n3 opsi: Kamera, Galeri, Batal;
  |#E8F5E9|Masyarakat|
  if (Pilih sumber?) then (Kamera)
    :Buka Kamera (ImagePicker);
  else (Galeri)
    :Buka Galeri (ImagePicker);
  endif
  |#FFF9C4|Sistem|
  :Ambil gambar\n(imageQuality: 75);
  :Tampilkan Preview Foto\n(tombol Ganti & Hapus);
else (Tidak)
  :Lanjut tanpa lampiran;
endif

|#E8F5E9|Masyarakat|
:Tekan "Kirim Pengaduan";

|#FFF9C4|Sistem|
:Validasi Seluruh Form;

if (Validasi berhasil?) then (Tidak)
  :Tampilkan error pada field;
  |#E8F5E9|Masyarakat|
  :Perbaiki input;
  stop
endif

:Tampilkan Loading Overlay;

if (Ada file lampiran?) then (Ya)
  :Upload ke Cloudinary API\n(Dio POST, upload_preset: upload);
  :Terima secure_url;
else (Tidak)
  :attachment_url = null;
endif

:INSERT INTO pengaduan\n(user_id, name, nik, date,\naddress, description,\nattachment_url,\nstatus = "menunggu");

if (Berhasil?) then (Ya)
  :Tutup Loading;
  :AppSnackbar.success\n("Pengaduan berhasil dikirim!");
  |#E8F5E9|Masyarakat|
  :Navigator.pop()\nKembali ke PengaduanView;
else (Gagal)
  :Tutup Loading;
  :AppSnackbar.error\n("Gagal mengirim pengaduan");
  |#E8F5E9|Masyarakat|
  :Tetap di form;
endif

stop

@enduml

@startuml Activity_06_Lihat_Pengaduan_User

skinparam roundcorner 10
skinparam BackgroundColor white
skinparam shadowing false
skinparam ActivityBackgroundColor #FEFEFE
skinparam ActivityBorderColor #555555
skinparam ActivityFontSize 11

title Activity Diagram 6 - Lihat Pengaduan Saya (User)\nSistem Informasi Kantor Lurah Maharatu

|#E8F5E9|Masyarakat|
start
:Pilih "Pengaduan Saya"\ndari PengaduanView;

|#FFF9C4|Sistem|
:fetchMyPengaduan()\nSELECT * FROM pengaduan\nWHERE user_id = auth.uid()\nORDER BY created_at DESC;

if (Query berhasil?) then (Ya)
  if (Data pengaduan ada?) then (Ya)
    :Tampilkan Daftar Pengaduan\n(Card: nama bold, status badge\ndengan warna & ikon, tanggal,\ndeskripsi max 2 baris);
  else (Kosong)
    :Tampilkan "Belum ada pengaduan";
  endif
else (Error)
  :Tampilkan pesan error\n+ tombol "Coba Lagi";
endif

|#E8F5E9|Masyarakat|
:Interaksi dengan daftar;
note right
  Fitur:
  - Search bar (filter nama,
    deskripsi, alamat)
  - Filter status chips
    (Semua, Menunggu, Diproses,
    Selesai, Ditolak)
  - Pull-to-refresh
  - Tombol refresh di AppBar
end note

:Pilih salah satu pengaduan;

|#FFF9C4|Sistem|
:Tampilkan PengaduanDetailView;
note right
  Konten Detail (read-only):
  - Banner status berwarna
    (ikon + "Status: label")
  - Catatan Admin (jika ada,
    container amber)
  - Nama, NIK, Tanggal (DD/MM/YYYY)
  - Alamat, Keterangan
  - Foto lampiran (jika ada,
    Image.network)
end note

|#E8F5E9|Masyarakat|
:Baca detail & status pengaduan;
:Kembali ke daftar;
stop

@enduml

