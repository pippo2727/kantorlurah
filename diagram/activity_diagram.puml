@startuml Activity_01_Splash_dan_Welcome

skinparam roundcorner 10
skinparam BackgroundColor white
skinparam shadowing false
skinparam ActivityBackgroundColor #FEFEFE
skinparam ActivityBorderColor #555555
skinparam ActivityFontSize 11

title Activity Diagram 1 - Splash Screen & Halaman Welcome\nSistem Informasi Kantor Lurah Maharatu

|#E8F5E9|Pengguna|
start
:Buka Aplikasi;

|#FFF9C4|Sistem|
:Inisialisasi Supabase\n(URL + Anon Key);
:Tampilkan SplashView\n(Logo + "KELURAHAN MAHARATU PEKANBARU");
:Delay 3 detik;
:Navigasi dengan Fade Transition\n(1 detik) ke FirstView;
:Tampilkan FirstView;
note right
  Komponen FirstView:
  - Background image (70% tinggi)
  - Logo "PELAYANANKU"
  - Teks "SELAMAT DATANG"
  - Tombol "Masuk"
  - Tombol "Daftar"
end note

|#E8F5E9|Pengguna|
if (Pilih aksi?) then (Masuk)
  :Navigasi ke LoginView;
else (Daftar)
  :Navigasi ke RegisterView;
endif

stop

@enduml

@startuml Activity_02_Registrasi

skinparam roundcorner 10
skinparam BackgroundColor white
skinparam shadowing false
skinparam ActivityBackgroundColor #FEFEFE
skinparam ActivityBorderColor #555555
skinparam ActivityFontSize 11

title Activity Diagram 2 - Registrasi Akun\nSistem Informasi Kantor Lurah Maharatu

|#E8F5E9|Masyarakat|
start
:Pilih "Daftar" di FirstView;
:Tampilkan RegisterView;
:Isi Form Registrasi;
note right
  Field Form:
  - Nama Lengkap (min 2 karakter)
  - Tanggal Lahir (DatePicker, 1900-sekarang)
  - Email (harus mengandung @)
  - Password (min 6 karakter)
  - Konfirmasi Password (harus cocok)
end note
:Tekan Tombol "Daftar";

|#FFF9C4|Sistem|
:Validasi Form (_formKey);

if (Form valid?) then (Tidak)
  :Tampilkan pesan error\npada masing-masing field;
  |#E8F5E9|Masyarakat|
  :Perbaiki input;
  stop
endif

:Cek tanggal lahir != null;

if (Tanggal lahir diisi?) then (Tidak)
  :AppSnackbar.error\n("Tanggal lahir wajib diisi");
  |#E8F5E9|Masyarakat|
  :Perbaiki input;
  stop
endif

:Tampilkan Loading Overlay;
:Supabase Auth signUp\n(email, password, metadata:\nname, birth_date);
:Trigger handle_new_user()\nINSERT ke public.users;

if (Registrasi berhasil?) then (Ya)
  if (response.user != null?) then (Ya)
    :AppSnackbar.success\n("Pendaftaran berhasil!\nSilakan masuk.");
  else (Perlu konfirmasi email)
    :AppSnackbar.success\n("Cek email Anda\nuntuk konfirmasi...");
  endif
  :Tutup Loading;
  |#E8F5E9|Masyarakat|
  :Navigator.pop()\nKembali ke FirstView;
else (Gagal)
  :Tutup Loading;
  :AppSnackbar.error\n(AuthException.message /\n"Terjadi kesalahan");
  |#E8F5E9|Masyarakat|
  :Tetap di RegisterView;
endif

stop

@enduml

@startuml Activity_03_Login

skinparam roundcorner 10
skinparam BackgroundColor white
skinparam shadowing false
skinparam ActivityBackgroundColor #FEFEFE
skinparam ActivityBorderColor #555555
skinparam ActivityFontSize 11

title Activity Diagram 3 - Login\nSistem Informasi Kantor Lurah Maharatu

|#E8F5E9|Pengguna|
start
:Pilih "Masuk" di FirstView;
:Tampilkan LoginView;
:Masukkan Email & Password;
note right
  Validasi:
  - Email wajib, harus mengandung @
  - Password wajib
end note
:Tekan Tombol "Masuk";

|#FFF9C4|Sistem|
:Validasi Form;

if (Form valid?) then (Tidak)
  :Tampilkan error pada field;
  |#E8F5E9|Pengguna|
  :Perbaiki input;
  stop
endif

:Tampilkan Loading Overlay;
:Supabase signInWithPassword\n(email, password);

if (Autentikasi berhasil?) then (Tidak)
  :Tutup Loading;
  :AppSnackbar.error\n(e.message /\n"Terjadi kesalahan");
  |#E8F5E9|Pengguna|
  :Tetap di LoginView;
  stop
endif

:_ensureUserRow()\n(buat row public.users\njika belum ada);

if (email == admin@demo.com?) then (Ya - Admin)
  :Tutup Loading;
  :pushAndRemoveUntil\nAdminMainNavigationView;
  note right
    Admin 3 Tab:
    - Dashboard
    - Pengaduan
    - Profil
  end note
else (Tidak - Masyarakat)
  :fetchCurrentUserProfile()\nambil nama dari public.users;
  :Tutup Loading;
  :pushAndRemoveUntil\nUserMainNavigationView\n(name, email);
  note right
    User 3 Tab:
    - Beranda
    - Pengaduan
    - Profil
  end note
endif

|#E8F5E9|Pengguna|
:Tampilkan Halaman Utama;
stop

@enduml

