@startuml Activity_13_Logout

skinparam roundcorner 10
skinparam BackgroundColor white
skinparam shadowing false
skinparam ActivityBackgroundColor #FEFEFE
skinparam ActivityBorderColor #555555
skinparam ActivityFontSize 11

title Activity Diagram 13 - Logout\nSistem Informasi Kantor Lurah Maharatu

|#E8F5E9|Pengguna|
start
note right
  Logout dapat dilakukan dari 2 tempat:
  1. Tab Profil (User & Admin)
     -> dengan dialog konfirmasi
  2. Dashboard Admin (AppBar)
     -> tanpa dialog konfirmasi
end note

if (Logout dari mana?) then (Tab Profil)
  :Pilih "Keluar" (merah)\ndi NavProfileTabView;
  |#FFF9C4|Sistem|
  :Tampilkan AlertDialog\n"Keluar"\n"Anda yakin ingin keluar?";
  |#E8F5E9|Pengguna|
  if (Konfirmasi?) then (Ya - "Keluar")
    |#FFF9C4|Sistem|
    :SupabaseService.logout()\nSupabase signOut();
    :pushAndRemoveUntil\nFirstView()\n(hapus seluruh stack);
  else (Tidak - "Batal")
    :Dialog ditutup;
    |#E8F5E9|Pengguna|
    :Tetap di halaman profil;
    stop
  endif
else (Dashboard Admin AppBar)
  |#FFF9C4|Sistem|
  :SupabaseService.logout()\nSupabase signOut()\n(tanpa konfirmasi);
  :pushAndRemoveUntil\nFirstView()\n(hapus seluruh stack);
endif

|#E8F5E9|Pengguna|
:Kembali ke FirstView\n(halaman welcome);
stop

@enduml
